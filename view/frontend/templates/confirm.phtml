<?php
/**
 * @var \Cloudgento\Rma\Block\Confirm $block
 * @var \Magento\Framework\Escaper $escaper
 */

$order = $block->getData('order');
$comment = $block->getData('comment');

if (!$order) {
    return;
}
?>
<div class="withdrawal-confirm-container">
    <div class="withdrawal-notice">
        <p><?= $escaper->escapeHtml(
            __('Please review your order details below and confirm your withdrawal.')
        ) ?></p>
    </div>

    <div class="withdrawal-order-summary">
        <h2><?= $escaper->escapeHtml(__('Order Summary')) ?></h2>
        <table class="data table" id="withdrawal-order-table">
            <caption class="table-caption"><?= $escaper->escapeHtml(__('Order Information')) ?></caption>
            <tbody>
                <tr>
                    <th scope="row"><?= $escaper->escapeHtml(__('Order Number')) ?></th>
                    <td><?= $escaper->escapeHtml($order->getIncrementId()) ?></td>
                </tr>
                <tr>
                    <th scope="row"><?= $escaper->escapeHtml(__('Order Date')) ?></th>
                    <td><?= $escaper->escapeHtml(
                        $block->formatDate($order->getCreatedAt(), \IntlDateFormatter::LONG)
                    ) ?></td>
                </tr>
            </tbody>
        </table>

        <h3><?= $escaper->escapeHtml(__('Items Ordered')) ?></h3>
        <table class="data table table-order-items" id="withdrawal-items-table">
            <caption class="table-caption"><?= $escaper->escapeHtml(__('Items in this order')) ?></caption>
            <thead>
                <tr>
                    <th scope="col"><?= $escaper->escapeHtml(__('Product')) ?></th>
                    <th scope="col"><?= $escaper->escapeHtml(__('Qty')) ?></th>
                </tr>
            </thead>
            <tbody>
                <?php foreach ($order->getAllVisibleItems() as $item): ?>
                    <tr>
                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Product')) ?>">
                            <?= $escaper->escapeHtml($item->getName()) ?>
                        </td>
                        <td data-th="<?= $escaper->escapeHtmlAttr(__('Qty')) ?>">
                            <?= $escaper->escapeHtml((string) (int) $item->getQtyOrdered()) ?>
                        </td>
                    </tr>
                <?php endforeach; ?>
            </tbody>
        </table>
    </div>

    <form class="form withdrawal-confirm-form"
          action="<?= $escaper->escapeUrl($block->getSubmitAction()) ?>"
          method="post"
          id="withdrawal-confirm-form">
        <?= $block->getBlockHtml('formkey') ?>

        <input type="hidden" name="increment_id"
               value="<?= $escaper->escapeHtmlAttr($order->getIncrementId()) ?>"/>
        <input type="hidden" name="email"
               value="<?= $escaper->escapeHtmlAttr($order->getCustomerEmail()) ?>"/>
        <input type="hidden" name="postcode"
               value="<?= $escaper->escapeHtmlAttr(
                   $order->getBillingAddress() ? $order->getBillingAddress()->getPostcode() : ''
               ) ?>"/>
        <input type="hidden" name="comment"
               value="<?= $escaper->escapeHtmlAttr((string) $comment) ?>"/>

        <div class="actions-toolbar">
            <div class="primary">
                <button type="submit"
                        class="action primary"
                        title="<?= $escaper->escapeHtmlAttr(__('Confirm Withdrawal')) ?>">
                    <span><?= $escaper->escapeHtml(__('Confirm Withdrawal')) ?></span>
                </button>
            </div>
            <div class="secondary">
                <a class="action back" href="<?= $escaper->escapeUrl($block->getCancelUrl()) ?>">
                    <span><?= $escaper->escapeHtml(__('Cancel')) ?></span>
                </a>
            </div>
        </div>
    </form>
</div>
