<?php
/**
 * @var \Cloudgento\Rma\Block\Form $block
 * @var \Magento\Framework\Escaper $escaper
 */
$formData = $block->getFormData();
$errorField = $formData['error_field'] ?? '';
?>
<?php if ($errorField): ?>
<style>.withdrawal-form .field-error input,.withdrawal-form .field-error textarea{border-color:#e02b27;background:#fff6f6;}</style>
<?php endif; ?>
<div class="withdrawal-form-container">
    <?php $introContent = $block->getIntroContent(); ?>
    <?php if ($introContent): ?>
        <div class="withdrawal-intro-content">
            <?= /* @noEscape */ $introContent ?>
        </div>
    <?php else: ?>
        <div class="withdrawal-intro">
            <p><?= $escaper->escapeHtml(
                __('Want to return your order? No problem. Under EU law you have the right to withdraw from your purchase within 14 days — no reason needed.')
            ) ?></p>
            <p><?= $escaper->escapeHtml(
                __('Simply fill in your order details below and we will process your return. You will receive a confirmation email with further instructions.')
            ) ?></p>
        </div>
    <?php endif; ?>

    <form class="form withdrawal-form"
          action="<?= $escaper->escapeUrl($block->getFormAction()) ?>"
          method="post"
          id="withdrawal-form"
          data-mage-init='{"validation":{}}'>
        <?= $block->getBlockHtml('formkey') ?>

        <fieldset class="fieldset">
            <legend class="legend">
                <span><?= $escaper->escapeHtml(__('Order Details')) ?></span>
            </legend>

            <div class="field required<?= $errorField === 'increment_id' ? ' field-error' : '' ?>">
                <label for="increment_id" class="label">
                    <span><?= $escaper->escapeHtml(__('Order Number')) ?></span>
                </label>
                <div class="control">
                    <input type="text"
                           name="increment_id"
                           id="increment_id"
                           class="input-text"
                           required
                           aria-required="true"
                           autocomplete="off"
                           value="<?= $escaper->escapeHtmlAttr($formData['increment_id']) ?>"
                           placeholder="<?= $escaper->escapeHtmlAttr(__('e.g. 100000001')) ?>"/>
                </div>
            </div>

            <div class="field required<?= $errorField === 'email' ? ' field-error' : '' ?>">
                <label for="email" class="label">
                    <span><?= $escaper->escapeHtml(__('Email Address')) ?></span>
                </label>
                <div class="control">
                    <input type="email"
                           name="email"
                           id="email"
                           class="input-text"
                           required
                           aria-required="true"
                           autocomplete="email"
                           value="<?= $escaper->escapeHtmlAttr($formData['email']) ?>"
                           data-validate='{"required-entry":true, "validate-email":true}'
                           placeholder="<?= $escaper->escapeHtmlAttr(__('Email used for the order')) ?>"/>
                </div>
            </div>

            <div class="field required<?= $errorField === 'postcode' ? ' field-error' : '' ?>">
                <label for="postcode" class="label">
                    <span><?= $escaper->escapeHtml(__('Postcode')) ?></span>
                </label>
                <div class="control">
                    <input type="text"
                           name="postcode"
                           id="postcode"
                           class="input-text"
                           required
                           aria-required="true"
                           autocomplete="postal-code"
                           value="<?= $escaper->escapeHtmlAttr($formData['postcode']) ?>"
                           placeholder="<?= $escaper->escapeHtmlAttr(__('Billing or shipping postcode')) ?>"/>
                </div>
            </div>

            <div class="field">
                <label for="comment" class="label">
                    <span><?= $escaper->escapeHtml(__('Comment (optional)')) ?></span>
                </label>
                <div class="control">
                    <textarea name="comment"
                              id="comment"
                              class="input-text"
                              rows="3"
                              aria-required="false"
                              placeholder="<?= $escaper->escapeHtmlAttr(__('Optional — you do not need to give a reason')) ?>"><?= $escaper->escapeHtml($formData['comment']) ?></textarea>
                </div>
            </div>
        </fieldset>

        <div class="withdrawal-legal-notice" style="margin:15px 0;padding:12px 15px;background:#f5f5f5;border-left:3px solid #333;font-size:13px;">
            <p style="margin:0;"><?= $escaper->escapeHtml(
                __('By clicking the button below, I formally withdraw from the contract for the above order in accordance with EU Directive 2011/83/EU (Article 11). This withdrawal is within the 14-day cooling-off period.')
            ) ?></p>
        </div>

        <div class="actions-toolbar">
            <div class="primary">
                <button type="submit" class="action primary" title="<?= $escaper->escapeHtmlAttr(__('Return my order')) ?>">
                    <span><?= $escaper->escapeHtml(__('Return my order')) ?></span>
                </button>
            </div>
        </div>
    </form>
</div>
